---
import Base from '../layouts/Base.astro';
import HeroInterno from '../components/HeroInterno.astro';
import Star from '../components/Star.astro';
---
<Base title="Contato — Casa Beliê, Laranjeiras RJ" description="Peça um orçamento para a festa: WhatsApp, e-mail e como chegar na Rua General Glicério, 131, Laranjeiras.">
  <HeroInterno kicker="Contato" headline="Bate na porta que a gente abre." strokeWord="abre" sub="Conte a festa que você imagina e a gente responde com um orçamento feito com carinho." surface="var(--manteiga)" starColor="#D98E6A" />

  <section>
    <div class="shell grid">
      <form id="form-orcamento" class="reveal" novalidate>
        <div class="field">
          <label for="nome">Seu nome</label>
          <input id="nome" name="nome" type="text" required autocomplete="name" />
          <span class="err">Conta pra gente o seu nome :)</span>
        </div>
        <div class="field">
          <label for="whats">Seu WhatsApp</label>
          <input id="whats" name="whats" type="tel" required autocomplete="tel" placeholder="(21) 9…" />
          <span class="err">Precisamos do seu número para responder.</span>
        </div>
        <div class="linha">
          <div class="field">
            <label for="data">Data desejada</label>
            <input id="data" name="data" type="text" placeholder="ex.: 14 de setembro" />
          </div>
          <div class="field">
            <label for="idade">Idade do aniversariante</label>
            <input id="idade" name="idade" type="text" placeholder="ex.: 5 anos" />
          </div>
        </div>
        <div class="field">
          <label for="convidados">Nº aproximado de convidados</label>
          <input id="convidados" name="convidados" type="text" placeholder="ex.: 60 pessoas" />
        </div>
        <div class="field">
          <label for="msg">Conte mais sobre a festa</label>
          <textarea id="msg" name="msg" rows="4" placeholder="tema, jeitinho da criança, o que não pode faltar…"></textarea>
        </div>
        <button class="btn" type="submit" data-evt="whatsapp-form">
          Enviar e continuar no WhatsApp <span class="arr">→</span>
          <svg class="scribble" viewBox="0 0 240 74" preserveAspectRatio="none" aria-hidden="true"><path d="M18 37 C 14 12, 80 6, 122 8 C 180 10, 232 16, 228 38 C 224 62, 160 68, 110 66 C 60 64, 20 58, 22 40" /></svg>
        </button>
        <p class="mini">Ao enviar, o WhatsApp abre com a sua mensagem pronta — é só apertar enviar por lá.</p>
      </form>

      <aside class="reveal" style="transition-delay:.12s">
        <span class="kicker k-lav"><Star /> Outros caminhos</span>
        <h2>Prefere direto?</h2>
        <p><strong>WhatsApp:</strong> <a href="https://wa.me/5521996694990?text=Ol%C3%A1!%20Quero%20saber%20mais%20sobre%20festas%20na%20Casa%20Beli%C3%AA%20:)" target="_blank" rel="noopener" data-evt="whatsapp">(21) 99669-4990</a></p>
        <p><strong>Instagram:</strong> <a href="https://www.instagram.com/casabelie/" target="_blank" rel="noopener">@casabelie</a></p>
        <p><strong>Onde fica:</strong> Rua General Glicério, 131 — Laranjeiras, Rio de Janeiro/RJ</p>
        <p><strong>Melhor horário:</strong> horário comercial, segunda a sexta.</p>
        <span class="nota-hand" aria-hidden="true">respondemos com calma e carinho</span>
      </aside>
    </div>
  </section>
</Base>

<style>
  .grid{display:grid;grid-template-columns:1.2fr .8fr;gap:clamp(32px,5vw,80px);align-items:start}
  @media(max-width:880px){.grid{grid-template-columns:1fr}}
  form{background:#fff;border-radius:22px;padding:clamp(24px,3vw,40px);border:1px solid rgba(58,52,64,.07)}
  .linha{display:grid;grid-template-columns:1fr 1fr;gap:16px}
  @media(max-width:560px){.linha{grid-template-columns:1fr}}
  .mini{font-size:.83rem;color:var(--ink-suave);margin-top:14px}
  aside h2{margin-bottom:18px}
  aside p{margin-bottom:12px}
  aside a{color:var(--lav-prof);font-weight:800;text-decoration:none}
  aside a:hover{text-decoration:underline}
  aside .nota-hand{color:var(--verde);transform:rotate(-2deg);margin-top:10px}
</style>

<script>
  const form = document.getElementById('form-orcamento');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    let ok = true;
    for (const id of ['nome', 'whats']) {
      const field = document.getElementById(id);
      const wrap = field.closest('.field');
      const valid = field.value.trim().length > 1;
      wrap.classList.toggle('invalid', !valid);
      if (!valid) ok = false;
    }
    if (!ok) return;
    const v = (id) => document.getElementById(id).value.trim();
    const linhas = [
      `Olá! Me chamo ${v('nome')} e quero um orçamento na Casa Beliê :)`,
      v('data') && `Data desejada: ${v('data')}`,
      v('idade') && `Aniversariante: ${v('idade')}`,
      v('convidados') && `Convidados: ${v('convidados')}`,
      v('msg') && `Sobre a festa: ${v('msg')}`,
      `Meu WhatsApp: ${v('whats')}`,
    ].filter(Boolean);
    window.open(`https://wa.me/5521996694990?text=${encodeURIComponent(linhas.join('\n'))}`, '_blank', 'noopener');
  });
</script>
