---
import Base from '../layouts/Base.astro';
import Star from '../components/Star.astro';
import CtaFinal from '../components/CtaFinal.astro';
import { getPublishedPosts } from '../lib/blogStore.js';

const posts = (await getPublishedPosts()).slice(0, 3);

const ambientes = [
  { nome: 'Quintal verde', desc: 'Grama, sombra e espaço de correr. O coração da Beliê fica ao ar livre.', nota: 'descalços, sempre' },
  { nome: 'Tanque de areia', desc: 'Mãos na areia, baldinhos e castelos — a brincadeira mais antiga do mundo.', nota: null },
  { nome: 'Muro de pintura', desc: 'Um muro inteiro para pintar de verdade, com tinta e pincel.', nota: 'pode sujar!' },
  { nome: 'Área molhada', desc: 'A prainha da casa para os dias quentes de verão carioca.', nota: null },
  { nome: 'Vila & casinha', desc: 'Um mundinho em escala de criança para inventar histórias.', nota: null },
  { nome: 'Espaço baby & sensorial', desc: 'Cantinho seguro e macio para os pequenininhos da festa.', nota: null },
];

const festas = [
  { num: '01', nome: 'Festa Beliê completa', desc: 'Espaço, buffet, decoração afetiva, recreação, atividades e equipe. Você chega, celebra e leva as memórias.' },
  { num: '02', nome: 'Festas escolares & encontros de turma', desc: 'Formato mais curto e prático para escolas, turmas e grupos de famílias.' },
  { num: '03', nome: 'Oficinas & experiências sazonais', desc: 'Roda de brincar, colônia de férias, arraiá, musicalização e encontros no quintal.' },
];
---
<Base overHero={true}>
  <!-- HERO -->
  <div class="hero-page hero-home">
    <div class="bg" aria-hidden="true">
      <img src="/images/r-hero-1600.jpg" srcset="/images/r-hero-900.jpg 900w, /images/r-hero-1600.jpg 1600w" sizes="100vw" width="1206" height="1600" alt="" fetchpriority="high" />
      <video class="hero-video" src="/videos/festa-sophia.mp4" poster="/images/r-hero-1600.jpg" autoplay muted loop playsinline preload="metadata"></video>
    </div>
    <div class="shell hero-inner">
      <span class="kicker"><Star color="#B9A5D8" size={18} /> Casa de festas infantil · Laranjeiras, RJ</span>
      <h1>
        <span class="line"><span>Onde a festa é</span></span>
        <span class="line"><span><span class="u-giz">brincar de verdade<svg viewBox="0 0 320 24" preserveAspectRatio="none" aria-hidden="true"><path d="M6 15 C 50 8, 95 19, 150 12 S 250 9, 314 14" /></svg></span>.</span></span>
      </h1>
      <p>Uma casa de 800 m² no coração de Laranjeiras: quintal verde, luz natural, tanque de areia, muro de pintura e zero telas. A festa completa para a sua família só viver o que importa.</p>
      <div class="actions">
        <a class="btn" href="https://wa.me/5521996694990?text=Ol%C3%A1!%20Quero%20saber%20mais%20sobre%20festas%20na%20Casa%20Beli%C3%AA%20:)" target="_blank" rel="noopener" data-evt="whatsapp">
          Pedir orçamento <span class="arr">→</span>
          <svg class="scribble" viewBox="0 0 240 74" preserveAspectRatio="none" aria-hidden="true"><path d="M18 37 C 14 12, 80 6, 122 8 C 180 10, 232 16, 228 38 C 224 62, 160 68, 110 66 C 60 64, 20 58, 22 40" /></svg>
        </a>
        <a class="btn ghost" href="/espaco/">Conhecer a casa</a>
      </div>
      <p class="confia">Festa completa: espaço, buffet, decoração, recreação e equipe <span aria-hidden="true">✳</span> +5 mil seguidores no <a href="https://www.instagram.com/casabelie/" target="_blank" rel="noopener">@casabelie</a></p>
    </div>
    <div class="nota" aria-hidden="true">
      <span class="hand">cada detalhe à mão ♡</span>
    </div>
  </div>

  <!-- MARQUEE -->
  <div class="marquee" aria-hidden="true">
    <div class="track">
      <span>quintal verde <i class="st">✳</i> luz natural <i class="st">✳</i> sem telas <i class="st">✳</i> brincar livre <i class="st">✳</i> decoração afetiva <i class="st">✳</i> festa completa <i class="st">✳</i></span>
      <span>quintal verde <i class="st">✳</i> luz natural <i class="st">✳</i> sem telas <i class="st">✳</i> brincar livre <i class="st">✳</i> decoração afetiva <i class="st">✳</i> festa completa <i class="st">✳</i></span>
    </div>
  </div>

  <!-- MANIFESTO -->
  <section class="manifesto">
    <div class="shell grid2">
      <figure class="reveal">
        <blockquote>"Aqui, cada encontro é recebido como quem abre a própria casa: com beleza, simplicidade e afeto, para que as crianças brinquem de verdade e as famílias vivam o que importa."</blockquote>
        <figcaption>— Isabela & Cecília, fundadoras · Madame Girafa e Vila Pindorama</figcaption>
      </figure>
      <div class="polaroid rot2 reveal" style="transition-delay:.15s">
        <span class="tape" aria-hidden="true"></span>
        <img src="/images/r-avo-1000.jpg" srcset="/images/r-avo-600.jpg 600w, /images/r-avo-1000.jpg 1000w" sizes="(max-width:880px) 92vw, 40vw" width="1000" height="639" alt="Avô mostra um sapinho para a neta no quintal da Casa Beliê, entre as cadeiras e o muro de pedra" loading="lazy" style="aspect-ratio:1000/639" />
        <span class="cap">alegria que atravessa gerações</span>
      </div>
    </div>
  </section>

  <!-- A CASA / AMBIENTES -->
  <section>
    <div class="shell">
      <span class="kicker k-verde reveal"><Star color="#3D5A34" /> A casa</span>
      <h2 class="reveal">800 m² de cantinhos para explorar.</h2>
      <p class="lead reveal">Numa rua bucólica de Laranjeiras, uma casa de dois andares onde tudo foi pensado para o brincar livre — e para os adultos ficarem tranquilos.</p>
      <div class="ambientes">
        {ambientes.map((a, i) => (
          <div class="amb reveal" style={`transition-delay:${i * 0.07}s`}>
            <h3>{a.nome}</h3>
            <p>{a.desc}</p>
            {a.nota && <span class="nota-hand" aria-hidden="true">{a.nota}</span>}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FESTAS -->
  <section class="festas">
    <div class="shell">
      <span class="kicker k-verde reveal"><Star color="#3D5A34" /> Festas & experiências</span>
      <h2 class="reveal">A festa inteira resolvida, do brigadeiro à recreação.</h2>
      <div class="lista">
        {festas.map((f, i) => (
          <a class="row reveal" href="/festas/" style={`transition-delay:${i * 0.08}s`}>
            <span class="num">{f.num}{f.num === '01' && <svg viewBox="0 0 90 60" class="stroke draw" style="--len:230" aria-hidden="true"><path d="M12 30 C 10 12, 40 6, 55 8 C 76 10, 84 22, 82 34 C 80 50, 52 56, 34 52 C 18 49, 10 40, 13 31" stroke="#B9A5D8" stroke-width="2.5" /></svg>}</span>
            <span><h3>{f.nome}</h3><p>{f.desc}</p></span>
            <span class="go" aria-hidden="true">→</span>
          </a>
        ))}
      </div>
      <p class="mais reveal"><a href="/festas/">Ver todas as festas e experiências →</a></p>
    </div>
  </section>

  <!-- MURO DE MEMÓRIAS -->
  <section class="muro">
    <div class="shell">
      <span class="kicker reveal" style="color:var(--manteiga)"><Star color="#F7E8C9" /> O muro de memórias</span>
      <h2 class="reveal">Cada festa deixa uma marca na casa.</h2>
      <p class="lead reveal">Como o nosso muro de pintura: cada festa deixa uma marca aqui. Momentos reais das nossas festas, direto do <a href="https://www.instagram.com/casabelie/" target="_blank" rel="noopener">@casabelie</a>.</p>
      <div class="fotos">
        <div class="polaroid g1 reveal"><span class="tape" aria-hidden="true"></span><img src="/images/r-baby-1000.jpg" srcset="/images/r-baby-600.jpg 600w, /images/r-baby-1000.jpg 1000w" sizes="(max-width:780px) 92vw, 30vw" width="563" height="1000" alt="Pai brincando de jogar a filha para o alto numa festa cheia de balões e flores na Casa Beliê" loading="lazy" style="aspect-ratio:3/4" /><span class="cap">alegria de verdade</span></div>
        <div class="polaroid g2 reveal" style="transition-delay:.1s"><span class="tape" aria-hidden="true"></span><img src="/images/r-mesa-1000.jpg" srcset="/images/r-mesa-600.jpg 600w, /images/r-mesa-1000.jpg 1000w" sizes="(max-width:780px) 92vw, 30vw" width="563" height="1000" alt="Sócia da Casa Beliê finalizando a mesa de bolo de uma festa de 1 aninho com tema circo" loading="lazy" style="aspect-ratio:3/4" /><span class="cap">cada detalhe da mesa ♡</span></div>
        <div class="polaroid g3 reveal" style="transition-delay:.2s"><span class="tape" aria-hidden="true"></span><img src="/images/r-bolo-1000.jpg" srcset="/images/r-bolo-600.jpg 600w, /images/r-bolo-1000.jpg 1000w" sizes="(max-width:780px) 92vw, 30vw" width="1000" height="907" alt="Calda de chocolate servida sobre bolo caseiro no prato 'fica, vai ter bolo' da Casa Beliê" loading="lazy" style="aspect-ratio:3/4" /><span class="cap">fica, vai ter bolo</span></div>
      </div>
      <span class="nota-hand assin reveal" aria-hidden="true">← cada festa deixa uma marca</span>
    </div>
  </section>

  <!-- FUNDADORAS -->
  <section class="fundadoras">
    <div class="shell">
      <span class="kicker k-lav reveal"><Star /> Quem abre a porta</span>
      <h2 class="reveal">Duas mães de casas que já fizeram muita festa.</h2>
      <div class="duo">
        <figure class="retrato-duo reveal">
          <div class="polaroid" style="transform:rotate(-1.6deg)">
            <span class="tape" aria-hidden="true"></span>
            <img src="/images/r-socias-1080.jpg" srcset="/images/r-socias-640.jpg 640w, /images/r-socias-1080.jpg 1080w" sizes="(max-width:760px) 92vw, 46vw" width="1080" height="520" alt="Isabela e Cecília, sócias da Casa Beliê, abraçadas e sorrindo" loading="lazy" />
            <span class="cap">Isabela &amp; Cecília ♡</span>
          </div>
        </figure>
        <div class="bios reveal" style="transition-delay:.1s">
          <article class="pessoa">
            <h3>Isabela</h3>
            <p>Fundadora da Madame Girafa, referência em festas afetivas e personalizadas no Rio de Janeiro desde 2014.</p>
          </article>
          <article class="pessoa">
            <h3>Cecília</h3>
            <p>Sócia da Vila Pindorama, casa de festas em Icaraí reconhecida pela proposta lúdica e acolhedora.</p>
          </article>
          <p class="nota-hand" aria-hidden="true">a gente cuida como se fosse da nossa família</p>
        </div>
      </div>
    </div>
  </section>

  <!-- NÚMEROS -->
  <section class="numeros">
    <div class="shell trio">
      <div class="reveal"><span class="serif n">800 m²</span><p>de casa e quintal</p></div>
      <div class="reveal" style="transition-delay:.1s"><span class="serif n">0</span><p>telas na festa</p></div>
      <div class="reveal" style="transition-delay:.2s"><span class="serif n">2</span><p>fundadoras com anos de festa na bagagem</p></div>
    </div>
  </section>

  <!-- NOVIDADES -->
  <section class="novidades">
    <div class="shell">
      <span class="kicker k-verde reveal"><Star color="#3D5A34" /> Novidades</span>
      <h2 class="reveal">O que anda acontecendo na casa.</h2>
      {posts.length > 0 ? (
        <div class="posts">
          {posts.map((p, i) => (
            <a class="post reveal" href={`/blog/${p.slug}/`} style={`transition-delay:${i * 0.08}s`}>
              <span class="data hand">{p.dateLabel}</span>
              <h3>{p.title}</h3>
              <p>{p.excerpt}</p>
              <span class="ler">Ler novidade →</span>
            </a>
          ))}
        </div>
      ) : (
        <p class="lead reveal">As primeiras novidades estão no forno. <span class="nota-hand">volta logo :)</span></p>
      )}
    </div>
  </section>

  <CtaFinal />
</Base>

<style>
  /* HERO — composição centralizada */
  .hero-home{align-items:center}
  .hero-page .bg{position:absolute;inset:0;z-index:-1}
  .hero-page .bg img{width:100%;height:100%;object-fit:cover;animation:heroZoom 2.4s var(--ease) both}
  @keyframes heroZoom{from{transform:scale(1.06)}to{transform:scale(1)}}
  .hero-video{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:50% 30%}
  @media (prefers-reduced-motion: reduce){.hero-video{display:none}}
  .hero-page .bg::after{content:"";position:absolute;inset:0;background:
    linear-gradient(to bottom, rgba(45,36,55,.40) 0%, rgba(45,36,55,.10) 16%, rgba(45,36,55,0) 30%),
    linear-gradient(to top, rgba(45,36,55,.52) 0%, rgba(45,36,55,.20) 46%, rgba(45,36,55,.04) 78%, rgba(45,36,55,0) 100%)}
  .hero-inner{width:100%;padding-top:110px;padding-bottom:clamp(40px,7vh,80px);color:#fff;
    display:flex;flex-direction:column;align-items:center;text-align:center}
  .hero-inner h1{font-size:clamp(2.6rem,6.6vw,5rem);margin:16px auto 16px;font-weight:340;letter-spacing:.01em;text-shadow:0 2px 24px rgba(45,36,55,.4)}
  @media(max-width:560px){.hero-inner h1{font-size:clamp(1.9rem,9vw,3.1rem)}}
  .hero-inner h1 .line{display:block;overflow:hidden;padding:0 .12em .24em;margin-bottom:-.24em}
  .hero-inner h1 .line>span{display:inline-block;transform:translateY(112%);animation:lineUp .8s var(--ease) forwards}
  .hero-inner h1 .line:nth-child(2)>span{animation-delay:.12s}
  @keyframes lineUp{to{transform:translateY(0)}}
  .hero-inner p{max-width:54ch;font-size:1.1rem;color:rgba(255,255,255,.93);margin:0 auto 28px;opacity:0;animation:fadeIn .9s .5s var(--ease) forwards;text-shadow:0 1px 12px rgba(45,36,55,.35)}
  .actions{display:flex;gap:16px;flex-wrap:wrap;justify-content:center;opacity:0;animation:fadeIn .9s .65s var(--ease) forwards}
  @keyframes fadeIn{to{opacity:1}}
  @media(max-width:480px){.actions{width:100%}.actions .btn{width:100%;justify-content:center}}
  .confia{font-size:.88rem!important;max-width:none!important;color:rgba(255,255,255,.82)!important;margin-top:26px!important;
    opacity:0;animation:fadeIn .9s .85s var(--ease) forwards}
  .confia span{color:var(--lav-brand);margin:0 8px}
  .confia a{color:#fff;font-weight:800;text-decoration:none;border-bottom:1.5px solid var(--lav-brand)}
  .confia a:hover{border-bottom-color:#fff}
  .nota{position:absolute;right:clamp(24px,6vw,90px);bottom:30vh;color:#fff;display:none;flex-direction:column;gap:2px;opacity:0;animation:fadeIn 1s 1.3s var(--ease) forwards}
  @media(min-width:1000px){.nota{display:flex}}
  .nota .hand{font-size:1.5rem;transform:rotate(-4deg)}

  /* MANIFESTO */
  .manifesto{background:var(--areia)}
  .grid2{display:grid;grid-template-columns:minmax(0,1.1fr) minmax(0,.9fr);gap:clamp(32px,5vw,80px);align-items:center}
  @media(max-width:880px){.grid2{grid-template-columns:1fr}}
  blockquote{font-family:Caveat,cursive;font-weight:500;font-size:clamp(1.7rem,3vw,2.3rem);line-height:1.3;transform:rotate(-.6deg)}
  figcaption{margin-top:18px;font-size:.9rem;color:var(--ink-suave)}
  .rot2{transform:rotate(2.2deg);max-width:440px}
  .polaroid img{height:auto}

  /* AMBIENTES */
  .ambientes{display:grid;grid-template-columns:repeat(3,1fr);gap:clamp(20px,3vw,40px);margin-top:44px}
  @media(max-width:900px){.ambientes{grid-template-columns:1fr 1fr}}
  @media(max-width:560px){.ambientes{grid-template-columns:1fr}}
  .amb{border-top:2px solid var(--areia);padding-top:20px;position:relative}
  .amb h3{font-size:1.25rem;margin-bottom:8px}
  .amb p{color:var(--ink-suave);font-size:.96rem}
  .amb .nota-hand{color:var(--verde);font-size:1.3rem;transform:rotate(-2deg);margin-top:8px}

  /* FESTAS */
  .festas{background:var(--papel)}
  .lista{margin-top:30px}
  .row{display:grid;grid-template-columns:76px 1fr auto;gap:clamp(16px,3vw,40px);align-items:center;
    padding:28px 12px;border-bottom:1px solid rgba(58,52,64,.12);text-decoration:none;
    transition:background .35s var(--ease),padding-left .35s var(--ease)}
  .row:hover{background:var(--brisa);padding-left:24px;border-radius:16px}
  .num{position:relative;font-family:"Fraunces",serif;font-size:1.6rem;color:var(--mata);text-align:center}
  .num svg{position:absolute;inset:-10px -8px;width:calc(100% + 16px);height:calc(100% + 20px)}
  .row h3{font-size:1.35rem;margin-bottom:3px}
  .row p{color:var(--ink-suave);font-size:.96rem;max-width:56ch}
  .go{width:46px;height:46px;border-radius:50%;border:1.5px solid var(--verde);display:grid;place-items:center;color:var(--mata);
    transition:background .3s,color .3s,transform .3s var(--ease)}
  .row:hover .go{background:var(--verde);color:#fff;transform:translateX(4px) rotate(-8deg)}
  @media(max-width:640px){.row{grid-template-columns:1fr auto}.num{display:none}}
  .mais{margin-top:24px}
  .mais a{color:var(--lav-prof);font-weight:800;text-decoration:none}
  .mais a:hover{text-decoration:underline}

  /* MURO */
  .muro{background:var(--mata);color:var(--papel)}
  .muro h2{color:var(--papel)}
  .muro .lead{color:rgba(253,250,244,.78)}
  .muro .lead a{color:var(--manteiga);font-weight:800;text-decoration:none;border-bottom:1.5px solid rgba(247,232,201,.5)}
  .muro .lead a:hover{border-bottom-color:var(--manteiga)}
  .fotos{display:grid;grid-template-columns:repeat(3,1fr);gap:clamp(20px,3vw,40px);margin-top:48px}
  @media(max-width:780px){.fotos{grid-template-columns:1fr;max-width:430px}}
  .g1{transform:rotate(-2.4deg)} .g2{transform:rotate(1.6deg) translateY(18px)} .g3{transform:rotate(-1.2deg)}
  .assin{color:var(--manteiga);font-size:1.5rem;transform:rotate(-3deg);margin-top:36px}

  /* FUNDADORAS */
  .fundadoras{background:var(--lav-veu)}
  .duo{display:grid;grid-template-columns:minmax(0,.95fr) minmax(0,1.05fr);gap:clamp(28px,5vw,72px);margin-top:44px;align-items:center}
  @media(max-width:760px){.duo{grid-template-columns:1fr;gap:36px}}
  .retrato-duo{margin:0}
  .retrato-duo .polaroid{padding:14px 14px 52px}
  .retrato-duo img{aspect-ratio:1080/520;object-position:center}
  .bios{display:flex;flex-direction:column;gap:20px}
  .pessoa{background:#fff;border-radius:18px;padding:26px 28px;border:1px solid rgba(58,52,64,.06)}
  .pessoa h3{font-size:1.3rem;margin-bottom:6px}
  .pessoa p{color:var(--ink-suave);font-size:.96rem}
  .bios .nota-hand{color:var(--lav-prof);font-size:1.4rem;transform:rotate(-2deg);margin-top:4px}

  /* NÚMEROS */
  .numeros .trio{display:grid;grid-template-columns:repeat(3,1fr);gap:32px;text-align:center}
  @media(max-width:640px){.numeros .trio{grid-template-columns:1fr}}
  .n{display:block;font-size:clamp(2.4rem,5vw,3.6rem);color:var(--lav-prof)}
  .numeros p{color:var(--ink-suave)}

  /* NOVIDADES */
  .novidades{background:var(--brisa)}
  .posts{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;margin-top:36px}
  @media(max-width:900px){.posts{grid-template-columns:1fr}}
  .post{background:#fff;border-radius:18px;padding:28px;text-decoration:none;border:1px solid rgba(58,52,64,.06);
    transition:transform .35s var(--ease),box-shadow .35s var(--ease)}
  .post:hover{transform:translateY(-4px);box-shadow:0 16px 32px -16px rgba(58,52,64,.25)}
  .post .data{color:var(--verde);font-size:1.2rem}
  .post h3{font-size:1.2rem;margin:8px 0 10px}
  .post p{color:var(--ink-suave);font-size:.93rem;margin-bottom:14px}
  .ler{color:var(--lav-prof);font-weight:800;font-size:.9rem}
</style>
