---
import Base from '../layouts/Base.astro';
import HeroInterno from '../components/HeroInterno.astro';
import Star from '../components/Star.astro';
import CtaFinal from '../components/CtaFinal.astro';

// Galeria com fotos reais do @casabelie (baixadas e tratadas). Faixas de texto do
// Instagram recortadas. Ampliar para o mínimo de 24 na versão final, com autorização.
// Mosaico bento: cada slot tem proporção fixa via CSS (object-fit:cover resolve o crop),
// evitando o esticamento de grid que sobrava espaço vazio quando as fotos tinham proporções diferentes.
const fotos = [
  { slot: 'f1', src: 'r-hero', big: 1600, sml: 900, alt: 'Mesa de doces com bolo de azulejo e limões e arco de balões azul e amarelo na Casa Beliê', cap: 'a mesa dos sonhos' },
  { slot: 'f2', src: 'r-mesa', big: 1000, sml: 600, alt: 'Sócia da Casa Beliê finalizando a mesa de bolo de uma festa de 1 aninho com tema circo', cap: 'cada detalhe importa' },
  { slot: 'f3', src: 'r-cafe', big: 1200, sml: 700, alt: 'Bandeja de café com fatia de bolo de chocolate no quintal da Casa Beliê', cap: 'aceita um café?' },
  { slot: 'f4', src: 'r-avo', big: 1000, sml: 600, alt: 'Avô mostra um sapinho para a neta no quintal da Casa Beliê', cap: 'alegria de geração em geração' },
];

const ambientes = ['Quintal verde', 'Tanque de areia', 'Muro de pintura', 'Área molhada', 'Vila & casinha', 'Espaço baby & sensorial', 'Salões de luz natural', 'Varandas & cantinhos'];
---
<Base title="O espaço da Casa Beliê — quintal verde e luz natural" description="Conheça os ambientes da casa: quintal, tanque de areia, muro de pintura, área molhada, vila, espaço baby e salões de luz natural.">
  <HeroInterno kicker="Espaço & galeria" headline="Uma casa feita de cantinhos." strokeWord="cantinhos" sub="800 m² em dois andares, entre o quintal e os salões de luz natural." surface="var(--areia)" starColor="#D98E6A" />

  <section>
    <div class="shell">
      <span class="kicker k-verde reveal"><Star color="#3D5A34" /> Os ambientes</span>
      <h2 class="reveal">Do tanque de areia ao salão de luz.</h2>
      <ul class="ambs reveal" role="list">
        {ambientes.map((a) => <li>{a}</li>)}
      </ul>
    </div>
  </section>

  <section class="galeria">
    <div class="shell">
      <span class="kicker reveal" style="color:var(--manteiga)"><Star color="#F7E8C9" /> Galeria</span>
      <h2 class="reveal">O muro de memórias da casa.</h2>
      <p class="lead reveal">Festas reais que já aconteceram na casa, direto do nosso <a href="https://www.instagram.com/casabelie/" target="_blank" rel="noopener">Instagram</a>. Em breve, ainda mais registros do espaço.</p>
      <div class="mural reveal">
        {fotos.map((f, i) => (
          <a class={`tile ${f.slot}`} href="https://www.instagram.com/casabelie/" target="_blank" rel="noopener" style={`transition-delay:${i * 0.06}s`}>
            <img src={`/images/${f.src}-${f.sml}.jpg`} srcset={`/images/${f.src}-${f.sml}.jpg ${f.sml}w, /images/${f.src}-${f.big}.jpg ${f.big}w`} sizes="(max-width:640px) 46vw, 22vw" width="700" height="700" alt={f.alt} loading="lazy" />
            <span class="véu" aria-hidden="true"></span>
            <span class="cap"><Star color="#F7E8C9" size={14} /> {f.cap}</span>
          </a>
        ))}
        <div class="tile f5" aria-hidden="true">
          <span class="ig-mais">
            <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.2" cy="6.8" r="1.1" fill="currentColor" stroke="none"/></svg>
            <span>mais fotos<br/>no @casabelie</span>
          </span>
        </div>
      </div>
    </div>
  </section>

  <section>
    <div class="shell mapa">
      <div class="reveal">
        <span class="kicker k-lav"><Star /> Onde fica</span>
        <h2>No coração de Laranjeiras.</h2>
        <p class="lead">Rua General Glicério, 131 — Laranjeiras, Rio de Janeiro/RJ. Rua bucólica, de fácil acesso pela Zona Sul.</p>
        <p class="acao"><a class="btn ghost dark" href="https://www.google.com/maps/search/?api=1&query=Casa%20Beli%C3%AA%20Rua%20General%20Glic%C3%A9rio%20131%20Laranjeiras%20Rio%20de%20Janeiro" target="_blank" rel="noopener" data-evt="mapa">Abrir no Google Maps</a></p>
      </div>
      <div class="mapa-frame reveal" style="transition-delay:.12s">
        <iframe title="Mapa — Casa Beliê, Rua General Glicério 131, Laranjeiras" src="https://www.google.com/maps?q=Rua%20General%20Glic%C3%A9rio%20131%20Laranjeiras%20Rio%20de%20Janeiro&output=embed" loading="lazy" referrerpolicy="no-referrer-when-downgrade" allowfullscreen></iframe>
      </div>
    </div>
  </section>

  <CtaFinal headline="Quer ver tudo isso pessoalmente?" sub="Agende uma visita — o café fica por nossa conta." nota="tem estacionamento na região" />
</Base>

<style>
  .ambs{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-top:32px;padding:0;list-style:none}
  @media(max-width:900px){.ambs{grid-template-columns:1fr 1fr}}
  .ambs li{background:var(--brisa);border-radius:14px;padding:16px 18px;font-weight:600}
  .galeria{background:var(--mata);color:var(--papel)}
  .galeria h2{color:var(--papel)}
  .galeria .lead{color:rgba(253,250,244,.78)}
  .galeria .lead a{color:var(--manteiga);font-weight:800;text-decoration:none;border-bottom:1.5px solid rgba(247,232,201,.5)}
  .galeria .lead a:hover{border-bottom-color:var(--manteiga)}
  /* Mosaico bento — cada slot tem proporção fixa, sem esticar por causa de fotos com aspect-ratio diferente */
  .mural{
    display:grid;
    grid-template-columns:repeat(4,1fr);
    grid-template-rows:repeat(2, clamp(120px,17vw,210px));
    grid-template-areas:"f1 f1 f2 f3" "f1 f1 f2 f5" "f4 f4 f4 f4";
    gap:clamp(10px,1.6vw,18px);
    margin-top:44px;
  }
  .tile{position:relative;display:block;border-radius:16px;overflow:hidden;text-decoration:none;
    box-shadow:0 10px 26px -16px rgba(0,0,0,.45)}
  .tile img{width:100%;height:100%;object-fit:cover;display:block;transition:transform .6s var(--ease)}
  .tile:hover img{transform:scale(1.06)}
  .f1{grid-area:f1} .f2{grid-area:f2} .f3{grid-area:f3} .f5{grid-area:f5}
  .f4{grid-area:f4;height:clamp(140px,20vw,220px)}
  .f4 img{object-position:50% 35%}
  .véu{position:absolute;inset:0;background:linear-gradient(to top, rgba(30,26,20,.72) 0%, rgba(30,26,20,.12) 45%, rgba(30,26,20,0) 70%);
    opacity:0;transition:opacity .35s var(--ease)}
  .tile:hover .véu,.tile:focus-visible .véu{opacity:1}
  .cap{position:absolute;left:14px;right:14px;bottom:12px;color:#fff;font-size:.85rem;font-weight:700;
    display:flex;align-items:center;gap:6px;opacity:0;transform:translateY(6px);transition:opacity .35s var(--ease),transform .35s var(--ease)}
  .tile:hover .cap,.tile:focus-visible .cap{opacity:1;transform:translateY(0)}
  .f5{background:var(--manteiga);display:flex;align-items:center;justify-content:center;text-align:center;box-shadow:none}
  .ig-mais{display:flex;flex-direction:column;align-items:center;gap:6px;color:var(--mata);font-weight:800;font-size:.8rem;line-height:1.3}
  @media(max-width:640px){
    .mural{grid-template-columns:1fr 1fr;
      grid-template-rows:clamp(200px,58vw,280px) clamp(130px,34vw,190px) clamp(130px,34vw,190px);
      grid-template-areas:"f1 f1" "f2 f3" "f4 f4"}
    .f4{height:100%}
    .f5{display:none}
    .cap,.véu{opacity:1;transform:none}
    .véu{background:linear-gradient(to top, rgba(30,26,20,.62) 0%, rgba(30,26,20,0) 60%)}
  }
  .mapa{display:grid;grid-template-columns:1fr 1.1fr;gap:clamp(32px,5vw,72px);align-items:center}
  @media(max-width:880px){.mapa{grid-template-columns:1fr}}
  .mapa .acao{margin-top:22px}
  .mapa-frame{border-radius:20px;overflow:hidden;box-shadow:0 18px 40px -18px rgba(58,52,64,.3)}
  .mapa-frame iframe{width:100%;height:380px;border:0;display:block}
</style>
