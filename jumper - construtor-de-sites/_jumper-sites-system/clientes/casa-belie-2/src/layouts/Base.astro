---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const {
  title = 'Casa Beliê — Casa de festas infantil em Laranjeiras, RJ',
  description = 'Festas infantis afetivas e sem telas numa casa de 800 m² com quintal verde e luz natural, no coração de Laranjeiras.',
  overHero = false,
  noChrome = false,
} = Astro.props;
---
<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="icon" type="image/png" href="/images/logo-belie.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Caveat:wght@500;600&family=Fraunces:ital,opsz,wght@0,9..144,300..500;1,9..144,300..500&family=Nunito+Sans:ital,opsz,wght@0,6..12,400;0,6..12,600;0,6..12,800;1,6..12,400&display=swap" rel="stylesheet" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="pt_BR" />
  <!-- Integrações pendentes de IDs (briefing): GA4, Meta Pixel, Google Ads.
       Eventos a instrumentar: clique WhatsApp (data-evt="whatsapp"), envio de formulário, clique no mapa. -->
</head>
<body>
  <a class="skip-link" href="#conteudo">Pular para o conteúdo</a>
  {!noChrome && <Header overHero={overHero} />}
  <main id="conteudo">
    <slot />
  </main>
  {!noChrome && <Footer />}

  <script>
    // Revelações e traços: entram em cena uma única vez.
    const io = new IntersectionObserver((es) => es.forEach((e) => {
      if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
    }), { threshold: 0.15 });
    document.querySelectorAll('.reveal, .draw').forEach((el) => io.observe(el));
    document.documentElement.classList.add('hero-ready');
  </script>
</body>
</html>
