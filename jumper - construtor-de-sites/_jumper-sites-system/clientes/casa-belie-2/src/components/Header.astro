---
// Header fixo: transparente sobre hero com foto, sólido nas demais situações.
const { overHero = false } = Astro.props;
const nav = [
  { label: 'A casa', href: '/sobre/' },
  { label: 'Festas', href: '/festas/' },
  { label: 'Espaço', href: '/espaco/' },
  { label: 'Novidades', href: '/blog/' },
];
const current = Astro.url.pathname;
---
<header id="hd" class={overHero ? '' : 'solid static-solid'}>
  <a class="brand" href="/" aria-label="Casa Beliê — início">
    <img src="/images/logo-belie.png" alt="" width="249" height="249" />
    <span class="brand-name serif">Casa Beliê</span>
  </a>
  <nav aria-label="Navegação principal">
    {nav.map(item => (
      <a href={item.href} aria-current={current.startsWith(item.href) ? 'page' : undefined}>{item.label}</a>
    ))}
    <a class="cta" href="https://wa.me/5521996694990?text=Ol%C3%A1!%20Quero%20saber%20mais%20sobre%20festas%20na%20Casa%20Beli%C3%AA%20:)" target="_blank" rel="noopener">Pedir orçamento</a>
  </nav>
  <button id="menu-btn" aria-label="Abrir menu" aria-expanded="false" aria-controls="menu-mobile">
    <span></span><span></span>
  </button>
</header>

<div id="menu-mobile" hidden>
  <nav aria-label="Menu">
    <a href="/">Início</a>
    {nav.map(item => <a href={item.href}>{item.label}</a>)}
  </nav>
  <a class="btn" href="https://wa.me/5521996694990?text=Ol%C3%A1!%20Quero%20saber%20mais%20sobre%20festas%20na%20Casa%20Beli%C3%AA%20:)" target="_blank" rel="noopener">Pedir orçamento <span class="arr">→</span></a>
</div>

<style>
  header{position:fixed;inset:0 0 auto 0;z-index:50;display:flex;align-items:center;justify-content:space-between;
    padding:18px var(--gutter);transition:background .3s var(--ease),box-shadow .3s var(--ease),padding .3s var(--ease)}
  header.solid{background:rgba(253,250,244,.94);backdrop-filter:blur(8px);box-shadow:0 1px 0 rgba(58,52,64,.08);padding-top:12px;padding-bottom:12px}
  .brand{display:flex;align-items:center;gap:10px;text-decoration:none}
  .brand img{height:42px;width:auto;filter:brightness(0) invert(1);transition:filter .3s}
  header.solid .brand img{filter:none}
  .brand-name{font-size:1.25rem;color:#fff;transition:color .3s}
  header.solid .brand-name{color:var(--ink)}
  nav{display:flex;align-items:center;gap:clamp(14px,2.5vw,32px)}
  nav a{text-decoration:none;font-weight:600;font-size:.95rem;color:#fff;position:relative;transition:color .3s}
  header.solid nav a{color:var(--ink)}
  nav a:not(.cta)::after{content:"";position:absolute;left:0;bottom:-5px;height:2px;width:0;background:currentColor;border-radius:2px;transition:width .35s var(--ease)}
  nav a:not(.cta):hover::after,nav a:not(.cta)[aria-current="page"]::after{width:100%}
  nav .cta{background:var(--papel);color:var(--lav-prof);padding:11px 22px;border-radius:999px;font-weight:800;transition:transform .3s var(--ease),box-shadow .3s var(--ease)}
  nav .cta:hover{transform:translateY(-2px);box-shadow:0 8px 20px -6px rgba(0,0,0,.35)}
  header.solid nav .cta{background:var(--lav-prof);color:var(--papel)}

  #menu-btn{display:none;flex-direction:column;gap:6px;background:none;border:0;padding:10px;cursor:pointer}
  #menu-btn span{width:26px;height:2.5px;border-radius:2px;background:#fff;transition:background .3s,transform .3s var(--ease)}
  header.solid #menu-btn span{background:var(--ink)}
  @media(max-width:820px){
    nav{display:none}
    #menu-btn{display:flex}
  }

  #menu-mobile{position:fixed;inset:0;z-index:49;background:var(--papel);display:flex;flex-direction:column;justify-content:center;align-items:center;gap:8px;padding:80px var(--gutter) 48px}
  #menu-mobile[hidden]{display:none}
  #menu-mobile nav{display:flex;flex-direction:column;align-items:center;gap:18px;margin-bottom:40px}
  #menu-mobile nav a{font-family:"Fraunces",serif;font-size:1.9rem;color:var(--ink);text-decoration:none}
  #menu-mobile nav a:hover{color:var(--lav-prof)}
</style>

<script>
  const hd = document.getElementById('hd');
  if (hd && !hd.classList.contains('static-solid')) {
    const onScroll = () => hd.classList.toggle('solid', scrollY > 40);
    addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }
  const btn = document.getElementById('menu-btn');
  const panel = document.getElementById('menu-mobile');
  if (btn && panel) {
    const toggle = (open) => {
      panel.hidden = !open;
      btn.setAttribute('aria-expanded', String(open));
      btn.setAttribute('aria-label', open ? 'Fechar menu' : 'Abrir menu');
      document.body.style.overflow = open ? 'hidden' : '';
      if (open) panel.querySelector('a')?.focus();
    };
    btn.addEventListener('click', () => toggle(panel.hidden));
    addEventListener('keydown', (e) => { if (e.key === 'Escape' && !panel.hidden) { toggle(false); btn.focus(); } });
    panel.addEventListener('click', (e) => { if (e.target.closest('a')) toggle(false); });
  }
</script>
