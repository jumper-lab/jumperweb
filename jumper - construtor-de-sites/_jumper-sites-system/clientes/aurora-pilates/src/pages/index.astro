---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';

const title = 'Aurora Pilates & Movimento — Studio boutique em Batel, Curitiba';
const description = 'Pilates em aparelhos com turmas de até 3 pessoas, avaliação individual e acompanhamento técnico. Agende sua aula experimental no Batel, Curitiba.';

const services = [
  {
    name: 'Aula experimental avaliativa',
    description: 'Primeiro contato para entender objetivos e limitações. Conversa inicial, observação de mobilidade e indicação do melhor plano.',
    icon: 'clipboard-check',
    highlight: true
  },
  {
    name: 'Pilates em aparelhos',
    description: 'Turmas pequenas com acompanhamento próximo. Exercícios adaptados para cada nível.',
    icon: 'activity'
  },
  {
    name: 'Pilates terapêutico',
    description: 'Foco em dor, mobilidade e retorno gradual ao movimento. Indicado para quem vem de lesão ou tem restrições.',
    icon: 'heart-pulse'
  },
  {
    name: 'Treino de mobilidade',
    description: 'Sessões para melhorar postura, amplitude de movimento e controle corporal.',
    icon: 'move'
  },
  {
    name: 'Programa 60+ ativo',
    description: 'Movimento seguro para longevidade e autonomia. Trabalho adaptado para a faixa etária.',
    icon: 'sun'
  }
];

const testimonials = [
  {
    quote: 'Voltei a me movimentar sem medo depois de anos com dor lombar.',
    author: 'Renata M.'
  },
  {
    quote: 'As aulas são técnicas, mas o clima é leve. Eu me sinto acompanhada de verdade.',
    author: 'Paulo R.'
  },
  {
    quote: 'O espaço transmite calma e profissionalismo desde a chegada.',
    author: 'Camila S.'
  }
];
---
<Layout title={title} description={description}>
  <!-- Navigation -->
  <header class="nav" id="nav">
    <div class="nav-inner container">
      <a href="/" class="nav-logo">
        <span class="nav-logo-name">Aurora</span>
        <span class="nav-logo-sub">Pilates & Movimento</span>
      </a>
      <nav class="nav-links" aria-label="Navegação principal">
        <a href="#sobre">Sobre</a>
        <a href="#metodo">Método</a>
        <a href="#servicos">Serviços</a>
        <a href="#depoimentos">Depoimentos</a>
        <a href="#contato">Contato</a>
      </nav>
      <a href="https://wa.me/5541999991201?text=Quero%20agendar%20uma%20aula%20experimental" class="btn btn-primary nav-cta">Agendar</a>
      <button class="nav-hamburger" aria-label="Abrir menu" aria-expanded="false" id="menu-toggle">
        <span></span>
        <span></span>
      </button>
    </div>
  </header>

  <!-- Mobile Menu -->
  <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
    <nav class="mobile-menu-links">
      <a href="#sobre">Sobre</a>
      <a href="#metodo">Método</a>
      <a href="#servicos">Serviços</a>
      <a href="#depoimentos">Depoimentos</a>
      <a href="#contato">Contato</a>
      <a href="https://wa.me/5541999991201?text=Quero%20agendar%20uma%20aula%20experimental" class="btn btn-primary">Agendar aula experimental</a>
    </nav>
  </div>

  <main id="conteudo">
    <!-- Hero -->
    <section class="hero">
      <div class="hero-inner container">
        <div class="hero-content">
          <span class="eyebrow">Pilates & Movimento Consciente — Curitiba</span>
          <h1>Movimento que cabe na sua vida, não na sua rotina.</h1>
          <p class="hero-sub">Studio boutique com turmas de até 3 pessoas, avaliação individual e acompanhamento técnico próximo. Para quem quer se mover melhor, não apenas se exercitar.</p>
          <div class="hero-ctas">
            <a href="https://wa.me/5541999991201?text=Quero%20agendar%20uma%20aula%20experimental" class="btn btn-primary">Agendar aula experimental</a>
            <a href="#sobre" class="btn btn-secondary">Conhecer o studio</a>
          </div>
          <div class="hero-trust">
            <span>180+ alunos</span>
            <span class="trust-dot">·</span>
            <span>Turmas de até 3</span>
            <span class="trust-dot">·</span>
            <span>4,9 no Google</span>
          </div>
        </div>
        <div class="hero-image">
          <div class="hero-image-frame">
            <div class="hero-image-placeholder" aria-label="Pessoa se movimentando com consciência em studio de pilates luminoso e minimalista">
              <svg viewBox="0 0 400 500" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <rect width="400" height="500" rx="20" fill="#EDE8DE"/>
                <circle cx="200" cy="180" r="40" fill="#D4CFC5"/>
                <path d="M200 220 L200 340 M160 270 L240 270 M200 340 L160 420 M200 340 L240 420" stroke="#D4CFC5" stroke-width="3" stroke-linecap="round"/>
                <path d="M120 460 Q200 440 280 460" stroke="#5C6B4F" stroke-width="1" opacity="0.3"/>
              </svg>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Leaf Divider -->
    <div class="leaf-divider" aria-hidden="true">
      <svg viewBox="0 0 120 40" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M60 5 C45 5, 20 15, 10 35 C30 25, 50 20, 60 18 C70 20, 90 25, 110 35 C100 15, 75 5, 60 5Z" stroke="#5C6B4F" stroke-width="1" fill="none"/>
        <line x1="60" y1="18" x2="60" y2="38" stroke="#5C6B4F" stroke-width="1"/>
      </svg>
    </div>

    <!-- Trust Bar -->
    <section class="trust-bar">
      <div class="trust-bar-inner container">
        <div class="trust-stat">
          <span class="trust-number">180+</span>
          <span class="trust-label">Alunos acompanhados</span>
        </div>
        <div class="trust-stat">
          <span class="trust-number">3</span>
          <span class="trust-label">Alunos por turma</span>
        </div>
        <div class="trust-stat">
          <span class="trust-number">4,9</span>
          <span class="trust-label">Avaliação no Google</span>
        </div>
      </div>
    </section>

    <!-- Sobre -->
    <section class="about" id="sobre">
      <div class="about-inner container">
        <div class="about-image">
          <div class="about-image-placeholder" aria-label="Interior do studio de pilates com aparelhos organizados, luz natural e plantas">
            <svg viewBox="0 0 600 400" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <rect width="600" height="400" rx="20" fill="#EDE8DE"/>
              <rect x="50" y="200" width="120" height="80" rx="8" fill="#D4CFC5"/>
              <rect x="200" y="180" width="120" height="100" rx="8" fill="#D4CFC5"/>
              <rect x="350" y="190" width="120" height="90" rx="8" fill="#D4CFC5"/>
              <circle cx="100" cy="140" r="25" fill="#5C6B4F" opacity="0.2"/>
              <circle cx="500" cy="120" r="35" fill="#5C6B4F" opacity="0.15"/>
              <path d="M0 350 Q300 320 600 350" stroke="#5C6B4F" stroke-width="1" opacity="0.2"/>
            </svg>
          </div>
        </div>
        <div class="about-content">
          <span class="eyebrow">Sobre o studio</span>
          <h2>Um espaço pensado para o seu movimento</h2>
          <p>A Aurora nasceu da crença de que movimento bem orientado transforma a forma como a pessoa vive o próprio corpo. Não é academia, não é treino genérico. É um studio boutique onde cada aluno recebe avaliação individual, plano personalizado e acompanhamento técnico de perto — com turmas de no máximo 3 pessoas.</p>
          <div class="about-highlight">
            <p><strong>Avaliação individual antes de iniciar qualquer programa.</strong> A gente conversa, observa e entende o que o seu corpo precisa antes de tudo.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Diferenciais -->
    <section class="differentials" id="metodo">
      <div class="differentials-inner container">
        <div class="differentials-header">
          <span class="eyebrow">Nosso método</span>
          <h2>Por que não somos uma academia</h2>
        </div>
        <div class="differentials-grid">
          <div class="diff-item">
            <span class="diff-number">01</span>
            <div class="diff-content">
              <h3>Turmas de até 3</h3>
              <p>Acompanhamento próximo de verdade. Sem lotação, sem improviso, sem genérico.</p>
            </div>
          </div>
          <div class="diff-item">
            <span class="diff-number">02</span>
            <div class="diff-content">
              <h3>Avaliação inicial</h3>
              <p>Antes de qualquer exercício, a gente conversa, observa e entende o que o seu corpo precisa.</p>
            </div>
          </div>
          <div class="diff-item">
            <span class="diff-number">03</span>
            <div class="diff-content">
              <h3>Pilates + Fisioterapia</h3>
              <p>Integração entre pilates contemporâneo, fisioterapia preventiva e educação corporal.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Serviços -->
    <section class="services" id="servicos">
      <div class="services-inner container">
        <div class="services-header">
          <span class="eyebrow">Serviços</span>
          <h2>O que oferecemos</h2>
        </div>
        <div class="services-grid">
          {services.map((service, i) => (
            <div class={`service-card ${service.highlight ? 'service-card--highlight' : ''}`}>
              {service.highlight && <span class="service-badge">Agende agora</span>}
              <div class="service-icon" aria-hidden="true">
                {service.icon === 'clipboard-check' && (
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/><path d="M9 14l2 2 4-4"/></svg>
                )}
                {service.icon === 'activity' && (
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
                )}
                {service.icon === 'heart-pulse' && (
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19.5 12.572l-7.5 7.428l-7.5-7.428A5 5 0 1112 6.006a5 5 0 017.5 6.572"/><path d="M6 12h2l2-4 4 8 2-4h2"/></svg>
                )}
                {service.icon === 'move' && (
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 9l-3 3 3 3"/><path d="M9 5l3-3 3 3"/><path d="M15 19l-3 3-3-3"/><path d="M19 9l3 3-3 3"/><line x1="2" y1="12" x2="22" y2="12"/><line x1="12" y1="2" x2="12" y2="22"/></svg>
                )}
                {service.icon === 'sun' && (
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="M4.93 4.93l1.41 1.41"/><path d="M17.66 17.66l1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="M6.34 17.66l-1.41 1.41"/><path d="M19.07 4.93l-1.41 1.41"/></svg>
                )}
              </div>
              <h3>{service.name}</h3>
              <p>{service.description}</p>
              {service.highlight && (
                <a href="https://wa.me/5541999991201?text=Quero%20agendar%20uma%20aula%20experimental" class="btn btn-primary">Agendar aula experimental</a>
              )}
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Depoimentos -->
    <section class="testimonials" id="depoimentos">
      <div class="testimonials-inner container">
        <div class="testimonials-header">
          <span class="eyebrow">Depoimentos</span>
          <h2>O que nossos alunos dizem</h2>
        </div>
        <div class="testimonial-carousel">
          {testimonials.map((t, i) => (
            <div class={`testimonial-item ${i === 0 ? 'testimonial-item--active' : ''}`} data-index={i}>
              <div class="testimonial-quote-mark" aria-hidden="true">"</div>
              <blockquote>
                <p>{t.quote}</p>
              </blockquote>
              <cite>— {t.author}</cite>
            </div>
          ))}
          <div class="testimonial-dots">
            {testimonials.map((_, i) => (
              <button class={`testimonial-dot ${i === 0 ? 'testimonial-dot--active' : ''}`} data-index={i} aria-label={`Depoimento ${i + 1}`}></button>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Final -->
    <section class="cta-final" id="contato">
      <div class="cta-final-inner container">
        <span class="eyebrow eyebrow--dark">Comece agora</span>
        <h2>Agende sua aula experimental</h2>
        <p>Primeiro contato para entender objetivos e limitações. Conversa inicial, observação de mobilidade e indicação do melhor plano.</p>
        <a href="https://wa.me/5541999991201?text=Quero%20agendar%20uma%20aula%20experimental" class="btn btn-primary">Agendar aula experimental</a>
        <span class="cta-final-note">Ou ligue para <a href="tel:+554133331201">(41) 3333-1201</a></span>
      </div>
    </section>

    <!-- Footer -->
    <footer class="footer">
      <div class="footer-inner container">
        <div class="footer-brand">
          <span class="footer-logo">Aurora</span>
          <span class="footer-logo-sub">Pilates & Movimento</span>
          <p class="footer-tagline">Studio boutique de pilates e movimento consciente para pessoas que querem força, mobilidade e bem-estar com acompanhamento próximo.</p>
        </div>
        <div class="footer-services">
          <h4>Serviços</h4>
          <ul>
            <li>Aula experimental avaliativa</li>
            <li>Pilates em aparelhos</li>
            <li>Pilates terapêutico</li>
            <li>Treino de mobilidade</li>
            <li>Programa 60+ ativo</li>
          </ul>
        </div>
        <div class="footer-contact">
          <h4>Contato</h4>
          <address>
            <p>Rua das Araucárias, 184<br/>Batel, Curitiba - PR<br/>80240-000</p>
            <p><a href="tel:+554133331201">(41) 3333-1201</a></p>
            <p><a href="https://wa.me/5541999991201">WhatsApp</a></p>
            <p><a href="mailto:contato@aurorapilatesmovimento.com.br">contato@aurorapilatesmovimento.com.br</a></p>
          </address>
          <div class="footer-hours">
            <p>Seg a Sex: 7h–20h</p>
            <p>Sáb: 8h–12h (agendamento)</p>
          </div>
        </div>
      </div>
      <div class="footer-legal container">
        <p>© 2026 Aurora Pilates & Movimento. Todos os direitos reservados.</p>
        <div class="footer-social">
          <a href="https://instagram.com/aurorapilates.movimento" aria-label="Instagram" target="_blank" rel="noopener">Instagram</a>
          <a href="https://facebook.com/aurorapilatesmovimento" aria-label="Facebook" target="_blank" rel="noopener">Facebook</a>
        </div>
      </div>
    </footer>
  </main>
</Layout>

<style>
  /* Navigation */
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    height: 76px;
    background: rgba(248, 245, 239, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    transition: height var(--duration-base) var(--ease-standard), box-shadow var(--duration-base) var(--ease-standard);
  }

  .nav.scrolled {
    height: 64px;
    box-shadow: var(--shadow-xs);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
    gap: var(--space-lg);
  }

  .nav-logo {
    display: flex;
    flex-direction: column;
    text-decoration: none;
  }

  .nav-logo-name {
    font-family: var(--font-heading);
    font-size: 22px;
    font-weight: 400;
    color: var(--color-text);
    line-height: 1.1;
  }

  .nav-logo-sub {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-primary);
  }

  .nav-links {
    display: none;
    align-items: center;
    gap: var(--space-xl);
  }

  .nav-links a {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 500;
    color: var(--color-text);
    text-decoration: none;
    position: relative;
    padding: 4px 0;
  }

  .nav-links a::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 1.5px;
    background: var(--color-primary);
    transition: width var(--duration-base) var(--ease-out-soft);
  }

  .nav-links a:hover::after {
    width: 100%;
  }

  .nav-cta {
    display: none;
    padding: 10px 24px;
    font-size: 14px;
    min-height: 40px;
  }

  .nav-hamburger {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 12px;
    min-height: 48px;
    min-width: 48px;
    align-items: center;
    justify-content: center;
  }

  .nav-hamburger span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--color-text);
    transition: transform var(--duration-base) var(--ease-standard), opacity var(--duration-fast) var(--ease-standard);
  }

  .nav-hamburger.active span:first-child {
    transform: rotate(45deg) translateY(4px);
  }

  .nav-hamburger.active span:last-child {
    transform: rotate(-45deg) translateY(-4px);
  }

  @media (min-width: 768px) {
    .nav-links {
      display: flex;
    }
    .nav-cta {
      display: inline-flex;
    }
    .nav-hamburger {
      display: none;
    }
  }

  /* Mobile Menu */
  .mobile-menu {
    position: fixed;
    inset: 0;
    z-index: 999;
    background: var(--color-surface);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--duration-slow) var(--ease-out-soft);
  }

  .mobile-menu.active {
    opacity: 1;
    pointer-events: auto;
  }

  .mobile-menu-links {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xl);
  }

  .mobile-menu-links a {
    font-family: var(--font-heading);
    font-size: 32px;
    font-weight: 400;
    color: var(--color-text);
    text-decoration: none;
    opacity: 0;
    transform: translateY(16px);
    transition: opacity var(--duration-reveal) var(--ease-out-soft), transform var(--duration-reveal) var(--ease-out-soft);
  }

  .mobile-menu.active .mobile-menu-links a {
    opacity: 1;
    transform: translateY(0);
  }

  .mobile-menu.active .mobile-menu-links a:nth-child(1) { transition-delay: 80ms; }
  .mobile-menu.active .mobile-menu-links a:nth-child(2) { transition-delay: 160ms; }
  .mobile-menu.active .mobile-menu-links a:nth-child(3) { transition-delay: 240ms; }
  .mobile-menu.active .mobile-menu-links a:nth-child(4) { transition-delay: 320ms; }
  .mobile-menu.active .mobile-menu-links a:nth-child(5) { transition-delay: 400ms; }
  .mobile-menu.active .mobile-menu-links a:nth-child(6) { transition-delay: 480ms; }

  /* Hero */
  .hero {
    padding-top: calc(76px + var(--space-xxl));
    padding-bottom: var(--space-lg);
    min-height: 85vh;
    display: flex;
    align-items: center;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xxl);
    align-items: center;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .hero h1 {
    max-width: 14ch;
  }

  .hero-sub {
    color: var(--color-text-secondary);
    max-width: 50ch;
  }

  .hero-ctas {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    max-width: 360px;
  }

  .hero-trust {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--text-small);
    color: var(--color-text-muted);
    flex-wrap: wrap;
  }

  .trust-dot {
    color: var(--color-primary);
  }

  .hero-image {
    display: flex;
    justify-content: center;
  }

  .hero-image-frame {
    position: relative;
    max-width: 360px;
    width: 100%;
  }

  .hero-image-frame::before {
    content: '';
    position: absolute;
    top: -12px;
    right: -12px;
    bottom: 12px;
    left: 12px;
    border: 1px solid var(--color-primary);
    border-radius: var(--radius-lg);
    opacity: 0.3;
    z-index: -1;
  }

  .hero-image-placeholder {
    border-radius: var(--radius-lg);
    overflow: hidden;
    aspect-ratio: 4/5;
  }

  .hero-image-placeholder svg {
    width: 100%;
    height: 100%;
  }

  @media (min-width: 1024px) {
    .hero-inner {
      grid-template-columns: 55% 45%;
    }
    .hero-ctas {
      flex-direction: row;
    }
    .hero-image-frame {
      max-width: 100%;
    }
  }

  /* Trust Bar */
  .trust-bar {
    background: var(--color-surface-dark);
    padding: var(--space-xl) 0;
  }

  .trust-bar-inner {
    display: flex;
    justify-content: center;
    gap: var(--space-xxl);
    flex-wrap: wrap;
  }

  .trust-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xs);
  }

  .trust-number {
    font-family: var(--font-heading);
    font-size: clamp(36px, 3vw + 20px, 48px);
    font-weight: 300;
    color: var(--color-accent);
    line-height: 1;
  }

  .trust-label {
    font-size: var(--text-small);
    color: var(--color-text-on-dark-secondary);
  }

  /* About */
  .about {
    padding: var(--section-gap) 0;
  }

  .about-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xxl);
    align-items: center;
  }

  .about-image-placeholder {
