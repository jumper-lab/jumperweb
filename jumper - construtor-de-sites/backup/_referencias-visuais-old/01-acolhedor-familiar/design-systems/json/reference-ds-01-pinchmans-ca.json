  "risks_and_mitigations": [
    {
      "risk": "Dark brown dominance can become heavy across many sessions.",
      "mitigation": "Alternate cacao bands with warm paper/white sessions and use product photography as relief."
    },
    {
      "risk": "Hero text over food photography can lose contrast.",
      "mitigation": "Use source-like dark border band or overlay at rgba(44,33,30,.55+) before cream text."
    },
    {
      "risk": "Parallax and negative margins can collide on mobile.",
      "mitigation": "Freeze parallax below 768px and convert split/offset layouts to stacked flow."
    },
    {
      "risk": "Brand-specific logo/cross/sunrise could leak into client identity.",
      "mitigation": "Treat as reference ornaments; create new icons/marks per client."
    },
    {
      "risk": "Source Skeleton blue button token is unrelated to the brand.",
      "mitigation": "Flag as legacy and avoid mapping it to accent."
    },
    {
      "risk": "Full-screen menus can trap keyboard users if implemented casually.",
      "mitigation": "Use dialog semantics, focus trap and Esc close."
    }
